{
  "name": "Family-Budget",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nx run-many -t build -p api web scheduling",
    "dev": "nx run-many -t dev -p api web --parallel",
    "dev:api": "nx dev api",
    "dev:scheduling": "nx dev scheduling",
    "dev:web": "nx dev web",
    "migration:check": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:generate apps/api/src/modules/database/migrations/SchemaCheck -d apps/api/src/modules/database/data-source.ts --check",
    "migration:create": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:create",
    "migration:generate": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:generate -d apps/api/src/modules/database/data-source.ts",
    "migration:revert": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:revert -d apps/api/src/modules/database/data-source.ts",
    "migration:run": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:run -d apps/api/src/modules/database/data-source.ts",
    "migration:show": "TS_NODE_PROJECT=apps/api/tsconfig.app.json typeorm-ts-node-commonjs migration:show -d apps/api/src/modules/database/data-source.ts",
    "preview": "nx preview web",
    "postinstall": "nx run web:prepare",
    "lint": "eslint .",
    "typecheck": "nx run-many -t typecheck -p api web scheduling"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.86",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.2",
    "@nuxt/ui": "^4.9.0",
    "dotenv": "17.4.1",
    "nuxt": "^4.4.8",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.1",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nuxt/eslint": "^1.16.0",
    "@nx/js": "^23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/node": "^23.0.1",
    "@nx/nuxt": "^23.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "nx": "^23.0.1",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.8.0"
}
