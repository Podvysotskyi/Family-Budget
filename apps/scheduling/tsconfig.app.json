{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2023",
    "lib": ["ES2023"],
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDir": "../../apps",
    "outDir": "./dist",
    "baseUrl": "./src",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../api/src/modules/budgets/**/*.ts",
    "../api/src/modules/database/database.config.ts",
    "../api/src/modules/database/dto/database-config.dto.ts",
    "../api/src/modules/database/interfaces/database-config.interface.ts",
    "../api/src/modules/households/entities/**/*.ts",
    "../api/src/modules/households/households.repository.ts",
    "../api/src/modules/users/entities/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
