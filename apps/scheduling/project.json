{
  "name": "scheduling",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/scheduling/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start --watch --config apps/scheduling/nest-cli.json --entryFile scheduling/src/main"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build --config apps/scheduling/nest-cli.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/scheduling/tsconfig.app.json --noEmit"
      }
    }
  }
}
